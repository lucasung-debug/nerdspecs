{
  "name": "nerdspecs",
  "version": "0.3.0",
  "description": "Put on nerd glasses and the project becomes visible. Translate AI-built projects into human-readable explanations.",
  "type": "module",
  "bin": {
    "nerdspecs": "bin/nerdspecs.js",
    "nerdspecs-mcp": "bin/nerdspecs-mcp.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "bin/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/ tests/",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "readme",
    "documentation",
    "landing-page",
    "github-pages",
    "non-developer",
    "ai-tools",
    "bilingual",
    "korean"
  ],
  "author": "propo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasung-debug/nerdspecs.git"
  },
  "homepage": "https://github.com/lucasung-debug/nerdspecs#readme",
  "bugs": {
    "url": "https://github.com/lucasung-debug/nerdspecs/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.3.0",
    "ora": "^8.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
